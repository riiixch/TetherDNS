generator client {
    provider = "prisma-client"
    output   = "./../server/lib/prisma"
}

datasource db {
    provider = "sqlite"
}

model CloudflareAccount {
    id           Int      @id @default(autoincrement())
    providerType String   @default("cloudflare")
    label        String
    email        String?
    apiToken     String
    zones        Zone[]
    createdAt    DateTime @default(now())
}

model Zone {
    id        Int                @id @default(autoincrement())
    cfZoneId  String             @unique
    name      String
    accountId Int?
    account   CloudflareAccount? @relation(fields: [accountId], references: [id])
    records   DnsRecord[]
}

model User {
    id               Int        @id @default(autoincrement())
    username         String     @unique
    password         String
    twoFactorSecret  String?
    twoFactorEnabled Boolean    @default(false)
    auditLogs        AuditLog[]
    apiTokens        ApiToken[]
    createdAt        DateTime   @default(now())
}

model ApiToken {
    id         Int       @id @default(autoincrement())
    name       String
    tokenHash  String    @unique
    userId     Int
    user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    lastUsedAt DateTime?
    createdAt  DateTime  @default(now())
}

model DnsRecord {
    id           Int         @id @default(autoincrement())
    cfRecordId   String      @unique
    name         String
    type         String
    content      String
    isAutoUpdate Boolean     @default(false)
    proxied      Boolean     @default(false)
    updateToken  String?     @unique
    zoneId       Int
    zone         Zone        @relation(fields: [zoneId], references: [id])
    updateLogs   UpdateLog[]
}

model UpdateLog {
    id        Int       @id @default(autoincrement())
    oldIp     String?
    newIp     String
    status    String
    recordId  Int
    record    DnsRecord @relation(fields: [recordId], references: [id])
    message   String?
    createdAt DateTime  @default(now())
}

model Settings {
    id    Int    @id @default(autoincrement())
    key   String @unique
    value String
}

model NotificationChannel {
    id        Int      @id @default(autoincrement())
    type      String // "discord" | "line" | "email"
    label     String
    config    String // encrypted JSON
    enabled   Boolean  @default(true)
    createdAt DateTime @default(now())
}

model AuditLog {
    id        Int      @id @default(autoincrement())
    userId    Int
    user      User     @relation(fields: [userId], references: [id])
    action    String
    target    String
    details   String?
    createdAt DateTime @default(now())
}
